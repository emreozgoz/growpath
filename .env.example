# GrowPath - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# Application
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/growpath_dev"

# Prisma (optional - for shadow database during migrations)
SHADOW_DATABASE_URL="postgresql://postgres:password@localhost:5432/growpath_shadow"

# ============================================
# Redis Cache
# ============================================
REDIS_URL="redis://localhost:6379"

# For production (Upstash)
# REDIS_URL="rediss://default:your-password@your-upstash-url.upstash.io:6379"

# ============================================
# Authentication (NextAuth.js)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"

# OAuth Providers (Optional - for future use)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# OpenAI API
# ============================================
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_ORG_ID="" # Optional - leave empty if not using organization

# Model configuration
OPENAI_MODEL_FREE="gpt-3.5-turbo"
OPENAI_MODEL_PAID="gpt-4-turbo"

# Rate limiting
OPENAI_MAX_TOKENS_FREE=2000
OPENAI_MAX_TOKENS_PAID=4000

# ============================================
# Stripe Payments
# ============================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER="price_starter_monthly"
STRIPE_PRICE_PRO="price_pro_monthly"
STRIPE_PRICE_UNLIMITED="price_unlimited_monthly"

# ============================================
# Email Service (Resend)
# ============================================
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="GrowPath <noreply@growpath.app>"

# ============================================
# Monitoring & Error Tracking
# ============================================
# Sentry
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_ORG="your-org"
SENTRY_PROJECT="growpath"

# Vercel Analytics (auto-configured in Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# ============================================
# Feature Flags
# ============================================
ENABLE_SIGNUPS=true
ENABLE_OAUTH=false
ENABLE_AI_STREAMING=true
ENABLE_ANALYTICS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# AI-specific rate limiting (per user tier)
RATE_LIMIT_AI_FREE_DAILY=3
RATE_LIMIT_AI_STARTER_DAILY=10
RATE_LIMIT_AI_PRO_DAILY=30
RATE_LIMIT_AI_UNLIMITED_DAILY=999999

# ============================================
# Cache Configuration
# ============================================
CACHE_TTL_AI_RESPONSE=86400 # 24 hours in seconds
CACHE_TTL_USER_TIER=3600 # 1 hour
CACHE_TTL_SESSION=604800 # 7 days

# ============================================
# Development Tools
# ============================================
# Logging level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable detailed SQL logging
DEBUG_SQL=false

# Enable request logging
DEBUG_REQUESTS=false

# ============================================
# Production Only
# ============================================
# (These should only be set in production environment)

# VERCEL_URL=growpath.app
# DATABASE_URL=your-production-database-url
# REDIS_URL=your-production-redis-url
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
